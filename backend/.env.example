# ---------------------------------------------------------------------------
# Database (Prisma)
# ---------------------------------------------------------------------------
# DATABASE_URL = pooled connection used by the app at runtime.
# DIRECT_URL   = direct connection used by Prisma for migrations / db push.
#
# --- Local Docker Postgres (default docker-compose) ---
DATABASE_URL="postgresql://tasty:tasty@localhost:5432/tasty_food?schema=public"
DIRECT_URL="postgresql://tasty:tasty@localhost:5432/tasty_food?schema=public"
#
# --- Supabase (project ref: zldmxrhwhqkmpapekdas, region ap-northeast-1) ---
# Pooled (Supavisor, transaction mode, port 6543) — note pgbouncer flags:
# DATABASE_URL="postgresql://postgres.zldmxrhwhqkmpapekdas:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (session mode, port 5432) for migrations:
# DIRECT_URL="postgresql://postgres.zldmxrhwhqkmpapekdas:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="1d"

# ---------------------------------------------------------------------------
# Email (supplier notifications on PO submit) — uses the Resend HTTP API.
# Leave RESEND_API_KEY blank to disable email (submit still works; it just logs).
# Get a key at https://resend.com and verify a sender domain for EMAIL_FROM.
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Tasty Food <onboarding@resend.dev>"

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
